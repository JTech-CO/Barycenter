{
  "name": "barycenter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "^22.13.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "test:core": "vitest run src/core",
    "test:physics": "vitest run src/validation",
    "test:physics:long": "vitest run --config vitest.physics.config.js",
    "report:physics": "node scripts/generate-physics-report.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:run && pnpm build"
  },
  "dependencies": {
    "lz-string": "1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "typescript": "7.0.2",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
